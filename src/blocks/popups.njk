                        </svg>
                    </div>
                </div>
                <div class="popup-location">
                    <div class="popup-location__search">
                        <div class="popup-location__search-button">
                            <svg aria-hidden="true" width="17" height="17">
                                <use xlink:href="img/sprite.svg#search"></use>
                            </svg>
                        </div>
                        <input autocomplete="off" type="text" name="form[]" placeholder="Поиск по названию города">
                    </div>
                    <ul>
                        <li>
                            <a href="./">
                                <div class="popup-location__name">Москва</div>
                                <div class="popup-location__number">984</div>
                            </a>
                        </li>
                        <li>
                            <a href="./">
                                <div class="popup-location__name">Санкт-Петербург</div>
                                <div class="popup-location__number">819</div>
                            </a>
                        </li>
                        <li>
                            <a href="./">
                                <div class="popup-location__name">Казань</div>
                                <div class="popup-location__number">633</div>
                            </a>
                        </li>
                        <li>
                            <a href="./">
                                <div class="popup-location__name">Новосибирск</div>
                                <div class="popup-location__number">789</div>
                            </a>
                        </li>
                        <li>
                            <a href="./">
                                <div class="popup-location__name">Екатеринбург</div>
                                <div class="popup-location__number">501</div>
                            </a>
                        </li>
                        <li>
                            <a href="./">
                                <div class="popup-location__name">Нижний Новгород</div>
                                <div class="popup-location__number">452</div>
                            </a>
                        </li>
                        <li>
                            <a href="./">
                                <div class="popup-location__name">Ростов-на-Дону</div>
                                <div class="popup-location__number">635</div>
                            </a>
                        </li>
                        <li>
                            <a href="./">
                                <div class="popup-location__name">Самара</div>
                                <div class="popup-location__number">303</div>
